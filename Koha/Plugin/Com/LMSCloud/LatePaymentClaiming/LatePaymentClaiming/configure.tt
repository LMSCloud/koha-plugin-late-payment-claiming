[% USE raw %]
[% USE Asset %]
[% USE KohaDates %]
[% USE AuthorisedValues %]
[% USE Categories %]
[% USE Branches %]
[% USE JSON.Escape %]
[% USE Koha %]
[% USE Letters %]
[% SET footerjs = 1 %]
[% SET libraries = Branches.all %]
[% SET categories = Categories.all.unblessed %]

[% PROCESS 'patron-search.inc' %]

[% INCLUDE 'doc-head-open.inc' %]
 <title>Koha: Gebührenmahnung Plugin: Konfiguration</title>
[% INCLUDE 'doc-head-close.inc' %]
[% Asset.css("css/datatables.css") %]
<link rel="stylesheet" type="text/css" href="/api/v1/contrib/latepaymentclaiming/static/css/latepaymentclaiming.css" />
</head>
<body>
[% INCLUDE 'html_helpers.inc' %]
[% PROCESS 'restriction-types.inc' %]
[% INCLUDE 'cat-search.inc' %]

[% WRAPPER 'sub-header.inc' %]
    [% WRAPPER breadcrumbs %]
        [% WRAPPER breadcrumb_item %]
            <a href="/cgi-bin/koha/admin/admin-home.pl">Administration</a>
        [% END %]
        [% WRAPPER breadcrumb_item %]
            <a href="/cgi-bin/koha/plugins/plugins-home.pl">Plugins</a>
        [% END %]
        [% IF action == "edit_config" %]
            [% WRAPPER breadcrumb_item %]
                <a href="/cgi-bin/koha/plugins/run.pl?class=Koha%3A%3APlugin%3A%3ACom%3A%3ALMSCloud%3A%3ALatePaymentClaiming&method=configure">Gebührenmahnung Plugin</a>
            [% END %]
            [% WRAPPER breadcrumb_item bc_active= 1 %]
                <span>Gebührenmahnung: Mahnkonfiguration</span>
            [% END %]
        [% ELSE %]
            [% WRAPPER breadcrumb_item bc_active= 1 %]
                <span>Gebührenmahnung</span>
            [% END %]
        [% END %]
    [% END #/ WRAPPER breadcrumbs %]
[% END #/ WRAPPER sub-header.inc %]

<div class="main container-fluid">
    <div class="row">
        <div class="col-sm-12">
            <main>
                
                <h1>Gebührenmahnung Plugin: Konfiguration</h1>
                
                
                [% IF !action %]
                <!-- Notice our form here has no 'action', this is good, it means that our forms will always get passed back to 'plugins/run.pl'. You could hard code it instead if you prefer -->
                <form method="post">
                
                    <input type="hidden" name="class" value="[% CLASS %]"/>
                    <input type="hidden" name="method" value="[% METHOD %]"/>
                    
                    <fieldset class="rows">

                        <legend>Allgemeine Einstellungen zur Gebührenmahnung</legend>

                        <ol class="radio">
                            <li>
                                <label class="radio" for="batch_active">Mahne Gebühren im Tageslauf:</label>
                                
                                <label for="batch_active">
                                    [% IF batch_active %]
                                        <input type="radio" id="batch_active" name="batch_active" value="1" checked="checked" /> Ja
                                    [% ELSE %]
                                        <input type="radio" id="batch_active" name="batch_active" value="1" />
                                    [% END %]
                                    Ja
                                </label>
                                
                                <label for="no_batch_active">
                                    [% IF batch_active %]
                                        <input type="radio" id="no_batch_active" name="batch_active" value="0" />
                                    [% ELSE %]
                                        <input type="radio" id="no_batch_active" name="batch_active" value="0" checked="checked" />
                                    [% END %]
                                    Nein
                                </label>
                                
                                <span class="hint">Sollen Gebühren automatisch im Tageslauf gemahnt werden?</span>
                            </li>
                            <li>
                                <label class="radio" for="execution_month_days">Ausführungsfrequenz:</label>
                                <span>Die nachfolgenden einträge für die Angabe von Ausführungstagen orientiert sich an der Syntax von cron-Einträgen</span>
                            </li>
                            <li>
                                <label class="radio" for="execution_month_days">Ausführung an Tagen des Monats:</label>
                                <input name="execution_month_days" size="20" maxlength="256" value=[% execution_month_days | html %]>
                                <span>An cron-angelehnte Angabe für die Tage eines Monats, an denen das Skript ausgeführt werden soll.</span>
                            </li>
                            <li>
                                <label class="radio" for="execution_monthes">Ausführung in den Monaten:</label>
                                <input name="execution_monthes" size="20" maxlength="256" value=[% execution_monthes | html %]>
                                <span>An cron-angelehnte Angabe von Monaten, an denen das Skript ausgeführt werden soll.</span>
                            </li>
                            <li>
                                <label class="radio" for="execution_monthes">Ausführung an Wochentagen:</label>
                                <input name="execution_weekdays" size="20" maxlength="256" value=[% execution_weekdays | html %]>
                                <span>An cron-angelehnte Angabe von Wochentagen, an denen das Skript ausgeführt werden soll.</span>
                            </li>
                            <li>
                                [% IF ! execution_on_closing_days %][% execution_on_closing_days = 'yes' %][% END %]
                                <label class="radio" for="execution_on_closing_days">Verhalten an Schließtagen:</label>
                                <label for="execution_on_closing_days">
                                    [% IF execution_on_closing_days == 'yes' %]
                                        <input type="radio" id="execution_on_closing_days_yes" name="execution_on_closing_days" value="yes" checked="checked" />
                                    [% ELSE %]
                                        <input type="radio" id="execution_on_closing_days_yes" name="execution_on_closing_days" value="yes" />
                                    [% END %]
                                    <span>Gebührenmahnlauf durchführen</span>
                                </label>
                            </li>
                            <li>
                                <label class="radio" for="execution_on_closing_days">&nbsp;</label>
                                <label for="execution_on_closing_days">
                                    [% IF execution_on_closing_days == 'delay' %]
                                        <input type="radio" id="execution_on_closing_days_delay" name="execution_on_closing_days" value="delay" checked="checked" />
                                    [% ELSE %]
                                        <input type="radio" id="execution_on_closing_days_delay" name="execution_on_closing_days" value="delay" />
                                    [% END %]
                                    <span>Verschieben auf den nächsten Öffnungstag</span>
                                </label>
                            </li>
                            <li>
                                <label class="radio" for="execution_on_closing_days">&nbsp;</label>
                                <label for="execution_on_closing_days">
                                    [% IF execution_on_closing_days == 'no' %]
                                        <input type="radio" id="execution_on_closing_days_no" name="execution_on_closing_days" value="no" checked="checked" />
                                    [% ELSE %]
                                        <input type="radio" id="execution_on_closing_days_no" name="execution_on_closing_days" value="no" />
                                    [% END %]
                                    <span>Keine Ausführung an Geschlossentagen</span>
                                </label>
                            </li>
                            <li>
                                <label for="save_general">&nbsp;</label>
                                <input class="btn btn-xs" type="submit" name="save_general" value="Allgemeine Einstellungen speichern" />
                            </li>
                        </ol>
                    </fieldset>
                </form>

                <form method="put">
                    <fieldset class="rows">

                        <legend>Mahnkonfigurationen</legend>
                        
                        <table class="latepayment_configurations">
                            <thead>
                                <tr>
                                    <th class="latepayment_config_list_branch_head">Zweigstelle</th>
                                    <th class="latepayment_config_list_category_head">Benutzergruppe</th>
                                    <th class="latepayment_config_list_claim_settings_head">Mahneinstellungen</th>
                                    <th class="latepayment_config_list_actions_head">Aktion</th>
                                </tr>
                            </thead>
                            <tbody>
                                [% FOREACH configuration IN configurations %]
                                <tr>
                                    <td class="latepayment_config_list_branch">
                                        [% IF (configuration.library_id == '*' || !configuration.library_id) %]
                                        <em>Alle</em>
                                        [% ELSE %]
                                        [% Branches.GetName(configuration.library_id) | html %]
                                        [% END %]
                                    </td>
                                    <td class="latepayment_config_list_category">
                                        [% IF (configuration.category_id == '*' || !configuration.category_id) %]
                                        <em>Alle</em>
                                        [% ELSE %]
                                        [% Categories.GetName(configuration.category_id) | html %]
                                        [% END %]
                                    </td>
                                    <td class="latepayment_config_list_claim_settings">
                                        [% IF (configuration.levels_defined == 0) %]
                                        Keine Gebührenmahnung
                                        [% ELSIF (configuration.levels_defined == 1) %]
                                        1 Mahnstufe
                                        [% ELSE %]
                                        [% configuration.levels_defined %] Mahnstufen
                                        [% END %]
                                    </td>
                                    <td class="latepayment_config_list_actions">
                                        <a href="/cgi-bin/koha/plugins/run.pl?class=[% CLASS | uri %]&method=configure&do=edit&library_id=[% configuration.library_id | uri %]&category_id=[% configuration.category_id | uri %]" class="btn btn-default btn-xs"><i class="fa fa-pencil"></i> Bearbeiten</a>
                                        <a href="javascript:deleteLatePaymentClaimConfig('[% configuration.library_id | html %]','[% configuration.category_id | html %]')" class="btn btn-default btn-xs delete"><i class="fa fa-trash"></i> Löschen</a>
                                    </td>
                                </tr>
                                [% END %]
                                <tr>
                                    <td class="latepayment_config_list_branch">
                                        <select name="latepayment_config_branchcode" id="latepayment_config_branchcode">
                                            <option value="*">Alle</option>
                                            [% FOREACH branch IN Branches.all( unfiltered => 1, restrict => NoMobileStations) %]
                                                <option value="[% branch.branchcode | html %]">[% branch.branchname | html %]</option>
                                            [% END %]
                                        </select>
                                    </td>
                                    <td class="latepayment_config_list_category">
                                        <select name="latepayment_config_categorycode" id="latepayment_config_categorycode">
                                            <option value="*">Alle</option>
                                            [% FOREACH category IN Categories.all() %]
                                                <option value="[% category.categorycode | html %]">[% category.description | html %]</option>
                                            [% END %]
                                        </select>
                                    </td>
                                    <td class="latepayment_config_list_claim_settings">
                                        
                                    </td>
                                    <td class="latepayment_config_list_actions">
                                        <a href="javascript:latepayment_config_action_new()" class="editrule btn btn-default btn-xs"><i class="fa fa-plus"></i> Hinzufügen</a>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </fieldset>
                </form>
                [% END %]

                [% IF action == "edit_config" %]
                
                <p>
                    <a href="/cgi-bin/koha/plugins/run.pl?class=Koha%3A%3APlugin%3A%3ACom%3A%3ALMSCloud%3A%3ALatePaymentClaiming&method=configure">Zurück zur Konfigurationsübersicht</a>
                </p>
                <form method="get">
                
                    <input type="hidden" name="do" value="edit_general">
                    <input type="hidden" name="class" value="[% CLASS %]"/>
                    <input type="hidden" name="method" value="[% METHOD %]"/>
                    
                    <fieldset class="rows late_payment_edit_config">

                        <legend>Mahnkonfiguration</legend>

                        <div class="add_latepayment_config">
                            <table>
                                <thead>
                                    <tr>
                                        <th coplspan="2">Einstellungen für:</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <th>Zweigstelle</th>
                                        <td>
                                            [% IF (library_id == '*' || !library_id) %]
                                            <em>Alle</em>
                                            [% ELSE %]
                                            [% Branches.GetName(library_id) | html %]
                                            [% END %]
                                        </td>
                                    <tr>
                                    <tr>
                                        <th>Benutzergruppe</th>
                                        <td>
                                            [% IF (category_id == '*' || !category_id) %]
                                            <em>Alle</em>
                                            [% ELSE %]
                                            [% Categories.GetName(category_id) | html %]
                                            [% END %]
                                        </td>
                                    <tr>
                                </tbody>
                            </table>
                        </div>
                        
                        <div class="add_latepayment_claimlevel">
                            <a class="btn btn-xs" onclick="addLatePaymentClaimLevelConfig()"><i class="fa fa-plus" aria-hidden="true"></i> Mahnstufe hinzufügen</a>
                            <a class="btn btn-xs submit" onclick="saveLatePaymentClaimLevelConfig()"><i class="fa fa-floppy-o" aria-hidden="true"></i> Konfiguration speichern</a>
                        </div>

                        <div class="alert alert-success show-late-payment-claim-config-save-success" style="display:none; margin-top:15px">
                            Die Konfiguration wurde erfolgreich gespeichert.
                        </div>
                        <div class="alert alert-danger show-late-payment-claim-config-save-error" style="display:none; margin-top:15px">
                            Beim Speichern der Konfiguration trat ein Fehler auf.
                        </div>
                        <div id="latepayment_claim_config">

                        </div>
                        
                        <div id="latepayment_claim_config_default" style="display:none">
                            <div class="latepayment_claim">
                                <div class="latepayment_claimlevel">
                                    <div class="row"> 
                                        <div class="col-xs-3 latepayment_claimlevel_name">
                                            Mahnstufe <span class="latepayment_claimlevel_number">1</span>
                                        </div>
                                        <div class="col-xs-9">
                                            <a class="btn btn-xs latepayment_claimlevel_delete"><i class="fa fa-times" aria-hidden="true"></i> Löschen</a>
                                        </div>
                                    </div>
                                </div>
                                <table class="latepayment_claimlevel_configuration">
                                    <thead>
                                        <tr>
                                            <th colspan="3" class="latepayment_userselections_head">Auswahl der Benutzer</th>
                                        </tr>
                                        <tr>
                                            <th class="latepayment_userselection_nr_head" style="width:5%">
                                                Nr
                                            </th>
                                            <th class="latepayment_userselection_list_head" style="width:60%">
                                                Benutzerauswahl
                                            </th>
                                            <th class="latepayment_userselection_do_head" style="width:35%">
                                                <a class="btn btn-xs latepayment_claimlevel_add_selection"><i class="fa fa-plus" aria-hidden="true"></i> Hinzufügen</a>
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody class="latepayment_userselections_body">
                                    </tbody>
                                    <thead>
                                        <tr>
                                            <th colspan="3" class="latepayment_actions_head">Aktionen</th>
                                        </tr>
                                        <tr>
                                            <th class="latepayment_actions_nr_head">
                                                Nr
                                            </th>
                                            <th class="latepayment_actions_action_head">
                                                Aktion
                                            </th>
                                            <th class="latepayment_actions_do_head">
                                                <a class="btn btn-xs latepayment_claimlevel_add_action"><i class="fa fa-plus" aria-hidden="true"></i> Hinzufügen</a>
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody class="latepayment_actions_body">
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        
                    </fieldset>

                </form>
                [% END %]

                [% IF action != "edit_config" %]
                <hr/>
                <p>
                    <h5>Aktualisierungsstatus des Plugins:</h5>
                    [% IF last_upgraded %]
                        Das Plugin wurde zuletzt aktualisert am [% last_upgraded | $KohaDates with_hours => 1 %]
                    [% ELSE %]
                        Das Plugin wurde noch nicht aktualisiert.
                    [% END %]
                </p>
                [% END %]
            </main>
        </div>
    </div>
</div>

[% IF action == "edit_config" %]

    <!-- Patron list setup -->
    <div class="modal" id="selection_patron_list" tabindex="-1" role="dialog" aria-labelledby="action_selectionLabel">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="closebtn" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                    <h4 class="modal-title" id="action_selectionLabel">Liste der ausgewählten Benutzer</h4>
                </div>
                <div class="modal-body">
                    <table id="patronSearchResult" class="table table-striped dt-responsive" style="table-layout: fixed; width: 100%">
                        <thead>
                            <tr>
                                <th>Aus&shy;weis&shy;num&shy;mer</th>
                                <th>Name / Adresse</th>
                                <th>Gebüh&shy;ren</th>
                                <th>Geburts&shy;datum</th>
                                <th>Biblio&shy;thek</th>
                                <th>Benutzer&shy;gruppe</th>
                                <th>Läuft/&shy;lief ab am</th>
                                <th>Aus&shy;lei&shy;hen</th>
                                <th>Notiz</th>
                            </tr>
                        </thead>
                        <tbody>
                            
                        </tbody>
                    </table>
                </div> <!-- /.modal-body -->
                <div class="modal-footer">
                    <form>
                        <button type="button" class="btn btn-default deny" data-dismiss="modal">Abbrechen</button>
                    </form>
                </div> <!-- /.modal-footer -->
            </div> <!-- /.modal-content -->
        </div> <!-- /.modal-dialog -->
    </div> <!-- /.modal -->

    <!-- Actions setup -->
    <div class="modal" id="action_selection" tabindex="-1" role="dialog" aria-labelledby="action_selectionLabel">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="closebtn" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                    <h4 class="modal-title" id="action_selectionLabel">Bitte wählen Sie eine Aktion</h4>
                </div>
                <form id="add_latepayment_action_form" data-level="" data-index="">
                    <div class="modal-body">
                        [% WRAPPER tabs id="actiontabs" %]
                            [% WRAPPER tabs_nav %]
                                [% WRAPPER tab_item tabname= "action_claim_tab" bt_active=1 %] <span>Mahnung</span> [% END %]
                                [% WRAPPER tab_item tabname= "action_fee_tab" %] <span>Gebühr</span> [% END %]
                                [% WRAPPER tab_item tabname= "action_debarement_tab" %] <span>Sperre neu</span> [% END %]
                                [% WRAPPER tab_item tabname= "action_debarement_delete_tab" %] <span>Sperre löschen</span> [% END %]
                                [% WRAPPER tab_item tabname= "action_user_value_tab" %] <span>Feldwert</span> [% END %]
                                [% WRAPPER tab_item tabname= "action_add_list_tab" %] <span>Benutzerliste</span> [% END %]
                            [% END # /WRAPPER action_tabs_nav %]
                            [% WRAPPER tab_panels %]
                                [% WRAPPER tab_panel tabname="action_claim_tab" bt_active=1 %]
                                <fieldset class="rows">
                                    <legend>Versand einer Gebührenmahnung</legend>
                                    <ol class="radio">
                                        <li>
                                            <label class="radio" for="late_payment_claim_action_letter">Brieflayout:</label>
                                            <select name="late_payment_claim_action_letter" id="late_payment_claim_action_letter">
                                                [% FOREACH l IN patronLetters %]
                                                <option value="[% l.code | html %]" data-transports="[% l.message_transport_type  | html %]">[% l.name  | html %]</option>
                                                [% END %]
                                            </select>
                                        </li>
                                        <li>
                                            <label class="radio" for="late_payment_claim_action_letter_transport_type">Versandart:</label>
                                            <select name="late_payment_claim_action_letter_transport_type" id="late_payment_claim_action_letter_transport_type">
                                                <option name="print">Brief</option>
                                                <option name="email">Email</option>
                                            </select>
                                        </li>
                                        <li>
                                            <label class="radio" for="nothing"></label>
                                        </li>
                                        <li>
                                            <label class="radio" for="late_payment_claim_action_letter_charge">Benach&shy;richti&shy;gungs&shy;gebühr:</label>
                                            <input type="number" step="0.01" lang="en" inputmode="decimal" pattern="^\d+(\.\d{2})?$" name="late_payment_claim_action_letter_charge" id="late_payment_claim_action_letter_charge" min="0" value="0.00" class="noEnterSubmit">
                                        </li>
                                        <li>
                                            <label class="radio" for="late_payment_claim_action_letter_charge_description">Beschreibung der Gebühr:</label>
                                            <input type="text" name="late_payment_claim_action_letter_charge_description" id="late_payment_claim_action_letter_charge_description" maxlength="250" value="Benachrichtigungsgebühr für [%claim.level %]. Gebührenmahnung">
                                        </li>
                                        <li>
                                            <label class="radio" for="late_payment_claim_action_letter_charge_note">Hinweis zur Gebühr:</label>
                                            <input type="text" name="late_payment_claim_action_letter_charge_note" id="late_payment_claim_action_letter_charge_note" maxlength="250" value="[%claim.level %]. Gebührenmahnung vom [% today %]">
                                        </li>
                                    </ol>
                                </fieldset>
                                [% END %]
                                [% WRAPPER tab_panel tabname="action_fee_tab" %]
                                <fieldset class="rows">
                                    <legend>Festlegung einer Gebühr</legend>
                                    <ol class="radio">
                                        <li>
                                            <label class="radio" for="late_payment_claim_action_fee_debit_type">Gebührenart:</label>
                                            <select name="late_payment_claim_action_fee_debit_type" id="late_payment_claim_action_fee_debit_type">
                                                [% FOREACH debit_type IN debit_types %]
                                                    [% IF debit_type.code %]
                                                        <option value="[% debit_type.code | html %]" data-default="[% debit_type.default_amount | html %]" data-description="[% debit_type.description | html %]">[% debit_type.description | html %]</option>
                                                    [% END %]
                                                [% END %]
                                            </select>
                                        </li>
                                        <li>
                                            <label class="radio" for="late_payment_claim_action_fee_amount">Gebührenbetrag:</label>
                                            <input type="number" step="0.01" lang="en" inputmode="decimal" pattern="^\d+(\.\d{2})?$" name="late_payment_claim_action_fee_amount" id="late_payment_claim_action_fee_amount" min="0.01" value="0.01" class="noEnterSubmit">
                                        </li>
                                        <li>
                                            <label class="radio" for="late_payment_claim_action_fee_description">Beschreibung der Gebühr:</label>
                                            <input type="text" name="late_payment_claim_action_fee_description" id="late_payment_claim_action_fee_description" maxlength="250">
                                        </li>
                                        <li>
                                            <label class="radio" for="late_payment_claim_action_fee_note">Hinweis zur Gebühr:</label>
                                            <input type="text" name="late_payment_claim_action_fee_note" id="late_payment_claim_action_fee_note" maxlength="250">
                                        </li>
                                    </ol>
                                </fieldset>
                                [% END %]
                                [% WRAPPER tab_panel tabname="action_debarement_tab" %]
                                <fieldset class="rows">
                                    <legend>Hinzufügen einer Sperre</legend>
                                    <ol class="radio">
                                        [% IF Koha.Preference('PatronRestrictionTypes') %]
                                        <li>
                                            <label class="radio" for="late_payment_claim_action_debarement_type">Typ der Sperre:</label>
                                            <select name="late_payment_claim_action_debarement_type" id="late_payment_claim_action_debarement_type">
                                                [% FOREACH restriction_type IN restriction_types %]
                                                    [% IF !restriction_type.is_system %]
                                                        [% IF restriction_type.is_default %]
                                                        <option value="[% restriction_type.code | html %]" selected>[% PROCESS restriction_type_description %]</option>
                                                        [% ELSE %]
                                                        <option value="[% restriction_type.code | html %]">[% PROCESS restriction_type_description %]</option>
                                                        [% END %]
                                                    [% END %]
                                                [% END %]
                                            </select>
                                        </li>
                                        [% END %]
                                        <li>
                                            <label class="radio" for="late_payment_claim_action_debarement_comment">Kommentar:</label>
                                            <input type="text" id="late_payment_claim_action_debarement_comment" name="late_payment_claim_action_debarement_comment" size="35" maxlength="250">
                                        </li>
                                        <li>
                                            <label class="radio" for="late_payment_claim_action_debarement_expiration">Ablauf: </label>
                                            &nbsp;nach&nbsp;<input type="number" name="late_payment_claim_action_debarement_expiration" id="late_payment_claim_action_debarement_expiration" step="any" min="0" class="daysrange-input"> Tagen
                                        </li>
                                    </ol>
                                </fieldset>
                                [% END %]
                                [% WRAPPER tab_panel tabname="action_debarement_delete_tab" %]
                                <fieldset class="rows">
                                    <legend>Löschen von Sperren</legend>
                                    <ol class="radio">
                                        [% IF Koha.Preference('PatronRestrictionTypes') %]
                                        <li>
                                            <label class="radio" for="late_payment_claim_action_delete_debarement_type">
                                                <input type="radio" value="type" name="late_payment_claim_action_delete_debarement" id="late_payment_claim_action_delete_debarement_type">Lösche Sperren des Typs
                                            </label>
                                            <select name="late_payment_claim_action_delete_debarement_types" id="late_payment_claim_action_delete_debarement_types">
                                                [% FOREACH restriction_type IN restriction_types %]
                                                    [% IF !restriction_type.is_system %]
                                                        [% IF restriction_type.is_default %]
                                                        <option value="[% restriction_type.code | html %]" selected>[% PROCESS restriction_type_description %]</option>
                                                        [% ELSE %]
                                                        <option value="[% restriction_type.code | html %]">[% PROCESS restriction_type_description %]</option>
                                                        [% END %]
                                                    [% END %]
                                                [% END %]
                                            </select>
                                        </li>
                                        [% END %]
                                        <li>
                                            <label class="radio" for="late_payment_claim_action_delete_debarement_all">
                                                <input type="radio" value="all" name="late_payment_claim_action_delete_debarement" id="late_payment_claim_action_delete_debarement_all">Lösche alle Sperren
                                            </label>
                                        </li>
                                    </ol>
                                </fieldset>
                                [% END %]
                                [% WRAPPER tab_panel tabname="action_user_value_tab" %]
                                <fieldset class="rows">
                                    <legend>Feldwert in den Benutzerdaten setzen</legend>
                                    <ol class="radio">
                                        <li>
                                            <label class="radio" for="late_payment_claim_action_set_field_categorycode">
                                                <span>Benutzertyp:</span>
                                            </label>
                                            <select name="late_payment_claim_action_set_field_categorycode" id="late_payment_claim_action_set_field_categorycode">
                                                <option value=""></option>
                                                [% FOREACH category IN Categories.all() %]
                                                    <option value="[% category.categorycode | html %]">[% category.description | html %]</option>
                                                [% END %]
                                            </select>
                                        </li>
                                        <li class="late_payment_claim_action_set_field_with_li_append">
                                            <label class="radio" for="late_payment_claim_action_set_field_borrowernotes">
                                                <span>Ausleihnotiz:</span>
                                            </label>
                                            <input type="text" name="late_payment_claim_action_set_field_borrowernotes" id="late_payment_claim_action_set_field_borrowernotes" value="" />
                                            <label for="late_payment_claim_action_set_field_borrowernotes_append" class="late_payment_claim_action_set_field_append">
                                               <input type="checkbox" name="late_payment_claim_action_set_field_borrowernotes_append" id="late_payment_claim_action_set_field_borrowernotes_append" value="1" checked >
                                               Anhängen
                                            </label>
                                        </li>
                                        <li class="late_payment_claim_action_set_field_with_li_append">
                                            <label class="radio" for="late_payment_claim_action_set_field_opacnote">
                                                <span>OPAC-Notiz:</span>
                                            </label>
                                            <input type="text" name="late_payment_claim_action_set_field_opacnote" id="late_payment_claim_action_set_field_opacnote" value="" />
                                            <label for="late_payment_claim_action_set_field_opacnote_append" class="late_payment_claim_action_set_field_append">
                                               <input type="checkbox" name="late_payment_claim_action_set_field_opacnote_append" id="late_payment_claim_action_set_field_opacnote_append" value="1" checked >
                                               Anhängen
                                            </label>
                                        </li>
                                        <li>
                                            <label class="radio" for="late_payment_claim_action_set_field_dateexpiry_action">
                                                <span>Ablaufdatum:</span>
                                            </label>
                                            <select name="late_payment_claim_action_set_field_dateexpiry_action" id="late_payment_claim_action_set_field_dateexpiry_action">
                                                <option value=""></option>
                                                <option value="current">auf Tagesdatum</option>
                                                <option value="yesterday">auf Tag vor aktuellem Tag</option>
                                            </select>
                                        </li>
                                        [% IF ( patron_attributes_codes ) %]
                                            <li>
                                                <label class="radio" for="late_payment_claim_action_set_field_attribute_code">
                                                    <span>Benutzerattribut:</span>
                                                </label>
                                                <select name="late_payment_claim_action_set_field_attribute_code" id="late_payment_claim_action_set_field_attribute_code">
                                                    [% FOREACH pac IN patron_attributes_codes %]
                                                        <option value="[% pac.attribute_code | html %]" data-type="[% pac.type | html %]" data-category="[% pac.category_lib | html %]">[% pac.attribute_lib | html %]</option>
                                                    [% END %]
                                                </select>
                                            </li>
                                            <li>
                                                <label class="radio" for="late_payment_claim_action_set_field_attribute_value">
                                                    <span></span>
                                                </label>
                                                <span class="late_payment_claim_action_attribute_value"><input type="text" name="late_payment_claim_action_set_field_attribute_value" id="late_payment_claim_action_set_field_attribute_value" maxlength="250"></span>
                                                <span class="information_category hint" style="width:25%;float:right;"></span>
                                            </li>
                                        [% END %]
                                    </ol>
                                </fieldset>
                                [% END %]
                                [% WRAPPER tab_panel tabname="action_add_list_tab" %]
                                <fieldset class="rows">
                                    <legend>Hinzufügen zu oder Austragen aus einer Benutzerliste</legend>
                                    <ol class="radio">
                                        <li>
                                            <label class="radio" for="late_payment_claim_action_patron_list">Benutzerliste:</label>
                                            <select name="late_payment_claim_action_patron_list" id="late_payment_claim_action_patron_list">
                                                [% FOREACH list IN patron_lists %]
                                                    <option value="[% list.patron_list_id | html %]">[% list.name | html %]</option>
                                                [% END %]
                                            </select>
                                        </li>
                                        <li>
                                            <label class="radio" for="late_payment_list_action">Änderung:</label>
                                            <label for="late_payment_claim_action_patron_list_change">
                                                <input type="radio" id="late_payment_claim_action_patron_list_add" name="late_payment_claim_action_patron_list_change" value="add" checked />
                                                <label for="late_payment_claim_action_patron_list_add">Hinzufügen</label>
                                                <input type="radio" id="late_payment_claim_action_patron_list_delete" name="late_payment_claim_action_patron_list_change" value="delete" /> 
                                                <label for="late_payment_claim_action_patron_list_delete">Löschen</label>
                                            </label>
                                        </li>
                                    </ol>
                                </fieldset>
                                [% END %]
                            [% END # /WRAPPER tab_panels %]
                        [% END # /WRAPPER tabs %]
                    </div> <!-- /.modal-body -->
                </form> <!-- /#send_runtime_parameter -->
                <div class="modal-footer">
                    <form id="action_selection_modal_action">
                        <button type="submit" class="btn btn-default approve">Aktion übernehmen</button>
                        <button type="button" class="btn btn-default deny" data-dismiss="modal">Abbrechen</button>
                    </form>
                </div> <!-- /.modal-footer -->
            </div> <!-- /.modal-content -->
        </div> <!-- /.modal-dialog -->
    </div> <!-- /.modal -->


    <!-- Patron selection setup -->
    <div class="modal" id="patron_selection" tabindex="-1" role="dialog" aria-labelledby="action_selectionLabel">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="closebtn" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                    <h4 class="modal-title" id="action_selectionLabel">Wählen Sie Suchparameter für die Benutzerauswahl</h4>
                </div>
                <div class="modal-body">
                    <aside>
                        <form id="add_latepayment_patron_search_form" data-level="" data-index="">
                            <fieldset class="brief">
                                <h3>Benutzer suchen</h3>
                                <ol>
                                    <li>
                                        <label for="latepayment_search_claim_filter">Gebührenmahnstufe: </label>
                                        <select id="latepayment_search_claim_filter">
                                            <option value="">Keine Auswahl</option>
                                            <option value="any">Irgendeine</option>
                                            <option value="1">Stufe 1</option>
                                            <option value="2">Stufe 2</option>
                                            <option value="3">Stufe 3</option>
                                            <option value="4">Stufe 4</option>
                                            <option value="5">Stufe 5</option>
                                         </select>
                                         &nbsp;vor&nbsp;<input type="number" name="latepayment_search_claimdays_filter" id="latepayment_search_claimdays_filter" step="any" min="0" class="daysrange-input"> Tagen
                                         <label for="latepayment_search_claim_filter_negate" class="latepayment_search_option_negate">
                                            <input type="checkbox" name="latepayment_search_claim_filter_negate" id="latepayment_search_claim_filter_negate" value="1">
                                            Nicht
                                        </label>
                                    </li>
                                    <li>
                                        <label for="latepayment_search_patron_filter">Suche:</label>
                                        <input type="text" id="latepayment_search_patron_filter" value="" class="focus">
                                        <label for="latepayment_search_patron_filter_negate" class="latepayment_search_option_negate">
                                            <input type="checkbox" name="latepayment_search_patron_filter_negate" id="latepayment_search_patron_filter_negate" value="1">
                                            Nicht
                                        </label>
                                    </li>

                                    <li>
                                        <label for="latepayment_search_patron_field_filter">Suchfeld:</label>
                                        <select name="latepayment_search_patron_field_filter" id="latepayment_search_patron_field_filter">
                                            <option value="surname,firstname,othernames,cardnumber,userid,borrowernotes,middle_name">Standard</option>
                                            <option value="surname">Nachname</option>
                                            <option value="cardnumber">Ausweisnummer</option>
                                            <option value="email,emailpro,B_email">Alle E-mailadressen</option>
                                            <option value="borrowernumber">Benutzernummer</option>
                                            <option value="userid">Benutzername</option>
                                            <option value="phone,phonepro,B_phone,altcontactphone,mobile">Alle Telefonnummern</option>
                                            <option value="streetnumber,streettype,address,address2,city,state,zipcode,country">Vollständige Adresse</option>
                                            <option value="dateofbirth">Geburtsdatum</option>
                                            <option value="sort1">Statistik 1</option>
                                            <option value="sort2">Statistik 2</option>
                                            <option value="firstname">Vorname</option>
                                            <option value="othernames">Anderer Name</option>
                                            <option value="borrowernotes">Ausleihnotiz</option>
                                            <option value="middle_name">Zweiter Vorname</option>
                                        </select>
                                    </li>
                                    <li>
                                        <label for="latepayment_search_patron_searchtype_filter">Suchart:</label>
                                        <select name="latepayment_search_patron_searchtype_filter" id="latepayment_search_patron_searchtype_filter">
                                            <option value="starts_with" selected="selected">Beginnt mit</option>
                                            <option value="contains">Enthält</option>
                                        </select>
                                    </li>
                                    <li>
                                        <label for="latepayment_search_agerangestart_filter">Alter:</label>
                                        ab&nbsp; <input type="number" name="latepayment_search_agerangestart_filter" id="latepayment_search_agerangestart_filter" step="any" min="0" class="agerange-input">
                                        bis&nbsp; <input type="number" name="latepayment_search_agerangeend_filter" id="latepayment_search_agerangeend_filter" step="any" min="0" class="agerange-input"> Jahre
                                        <label for="latepayment_search_agerange_filter_negate" class="latepayment_search_option_negate">
                                            <input type="checkbox" name="latepayment_search_agerange_filter_negate" id="latepayment_search_agerange_filter_negate" value="1">
                                            Nicht
                                        </label>
                                    </li>
                                    <li>
                                        <label for="latepayment_search_issuecountstart_filter">Anzahl Ausleihen: </label>
                                        von&nbsp; <input type="number" name="latepayment_search_issuecountstart_filter" id="latepayment_search_issuecountstart_filter" step="any" min="0" class="issuecount-input">
                                        bis&nbsp; <input type="number" name="latepayment_search_issuecountend_filter" id="latepayment_search_issuecountend_filter" step="any" min="0" class="issuecount-input">
                                        <label for="latepayment_search_issuecount_filter_negate" class="latepayment_search_option_negate">
                                            <input type="checkbox" name="latepayment_search_issuecount_filter_negate" id="latepayment_search_issuecount_filter_negate" value="1">
                                            Nicht
                                        </label>
                                    </li>
                                    <li>
                                        <label for="latepayment_search_chargesfrom_filter">Ausstehende Gebühren:</label>
                                        von&nbsp; <input type="number" name="latepayment_search_chargesfrom_filter" id="latepayment_search_chargesfrom_filter" step="any" min="0" class="charges-input">
                                        bis&nbsp; <input type="number" name="latepayment_search_chargesto_filter" id="latepayment_search_chargesto_filter" step="any" min="0" class="charges-input">
                                        <label for="latepayment_search_charges_filter_negate" class="latepayment_search_option_negate">
                                            <input type="checkbox" name="latepayment_search_charges_filter_negate" id="latepayment_search_charges_filter_negate" value="1">
                                            Nicht
                                        </label>
                                   </li>
                                   <li>
                                       <label for="latepayment_search_chargessince_filter">Ausstehende Gebühren seit:</label>
                                       <input type="number" name="latepayment_search_chargessince_filter" id="latepayment_search_chargessince_filter" step="any" min="0" class="daysrange-input"> Tagen
                                       <label for="latepayment_search_chargessince_filter_negate" class="latepayment_search_option_negate">
                                            <input type="checkbox" name="latepayment_search_chargessince_filter_negate" id="latepayment_search_chargessince_filter_negate" value="1">
                                            Nicht
                                        </label>
                                   </li>
                                   <li>
                                       <label for="latepayment_search_accountexpiresfrom_filter">Konto läuft/lief ab: </label>
                                       vor&nbsp;<input type="number" name="latepayment_search_accountexpiresfrom_filter" id="latepayment_search_accountexpiresfrom_filter" step="any" min="0" class="daysrange-input">
                                       bis&nbsp;<input type="number" name="latepayment_search_accountexpiresfrom_filter" id="latepayment_search_accountexpiresto_filter" step="any" min="0" class="daysrange-input"> Tagen
                                       <label for="latepayment_search_accountexpires_filter_negate" class="latepayment_search_option_negate">
                                            <input type="checkbox" name="latepayment_search_accountexpires_filter_negate" id="latepayment_search_accountexpires_filter_negate" value="1">
                                            Nicht
                                        </label>
                                   </li>
                                   <li>
                                       <label for="latepayment_search_debarreduntilfrom_filter">Benutzersperre: </label>
                                       vor&nbsp;<input type="number" name="latepayment_search_debarreduntilfrom_filter" id="latepayment_search_debarreduntilfrom_filter" step="any" min="0" class="daysrange-input">
                                       bis&nbsp;<input type="number" name="latepayment_search_debarreduntilto_filter" id="latepayment_search_debarreduntilto_filter" step="any" min="0" class="daysrange-input"> Tagen
                                       <label for="latepayment_search_debarreduntil_filter_negate" class="latepayment_search_option_negate">
                                            <input type="checkbox" name="latepayment_search_debarreduntil_filter_negate" id="latepayment_search_debarreduntil_filter_negate" value="1">
                                            Nicht
                                        </label>
                                   </li>
                                   <li>
                                       <label for="latepayment_search_inactivesince_filter">Inaktiv seit (keine Ausleihen und Anmeldungen bei Online-Diensten):</label>
                                       <input type="number" name="latepayment_search_inactivesince_filter" id="latepayment_search_inactivesince_filter" step="any" min="0" class="daysrange-input"> Tagen
                                       <label for="latepayment_search_inactivesince_filter_negate" class="latepayment_search_option_negate">
                                            <input type="checkbox" name="latepayment_search_inactivesince_filter_negate" id="latepayment_search_inactivesince_filter_negate" value="1">
                                            Nicht
                                        </label>
                                   </li>
                                   <li>
                                       [% SET letters = Letters.all() %]
                                       <label for="latepayment_search_lastlettercode_filter">Letzte Benachrichtigung: </label>
                                       <select id="latepayment_search_lastlettercode_filter">
                                           <option value="">Keine Auswahl</option>
                                           [% FOREACH l IN letters %]
                                           <option value="[% l.code %]">[% l.name %]</option>
                                           [% END %]
                                        </select>
                                        <label for="latepayment_search_lastlettercode_filter_negate" class="latepayment_search_option_negate">
                                            <input type="checkbox" name="latepayment_search_lastlettercode_filter_negate" id="latepayment_search_lastlettercode_filter_negate" value="1">
                                            Nicht
                                        </label>
                                    </li>
                                    <li>
                                        <label for="latepayment_search_overduelevel_filter">Ausleihe mit Mahnstufe: </label>
                                        <select id="latepayment_search_overduelevel_filter">
                                            <option value="">Keine Auswahl</option>
                                            <option value="any">Irgendeine</option>
                                            <option value="1">Stufe 1</option>
                                            <option value="2">Stufe 2</option>
                                            <option value="3">Stufe 3</option>
                                            <option value="4">Stufe 4</option>
                                            <option value="5">Stufe 5</option>
                                         </select>
                                         <label for="latepayment_search_overduelevel_filter_negate" class="latepayment_search_option_negate">
                                            <input type="checkbox" name="latepayment_search_overduelevel_filter_negate" id="latepayment_search_overduelevel_filter_negate" value="1">
                                            Nicht
                                        </label>
                                     </li>
                                     <li>
                                         <label for="latepayment_search_validemailavailable_filter">E-Mail Adresse: </label>
                                         <select id="latepayment_search_validemailavailable_filter">
                                            <option value="">Keine Auswahl</option>
                                            <option value="yes">vorhanden</option>
                                            <option value="no">nicht vorhanden</option>
                                        </select>
                                        <label for="latepayment_search_validemailavailable_filter_negate" class="latepayment_search_option_negate">
                                            <input type="checkbox" name="latepayment_search_validemailavailable_filter_negate" id="latepayment_search_validemailavailable_filter_negate" value="1">
                                            Nicht
                                        </label>
                                    </li>
                                    <li>
                                        <label for="latepayment_search_patronlistid_filter">Benutzerliste:  </label>
                                        <select id="latepayment_search_patronlistid_filter">
                                            <option value="">Keine Auswahl</option>
                                            [% FOREACH p IN patron_lists %]
                                            <option value="[% p.patron_list_id %]">[% p.name %]</option>
                                            [% END %]
                                        </select>
                                        <label for="latepayment_search_patronlistid_filter_negate" class="latepayment_search_option_negate">
                                            <input type="checkbox" name="latepayment_search_patronlistid_filter_negate" id="latepayment_search_patronlistid_filter_negate" value="1">
                                            Nicht
                                        </label>
                                    </li>
                                </ol>
                            </fieldset>
                        </form>
                    </aside>
                </div> <!-- /.modal-body -->
                <div class="modal-footer">
                    <form id="patron_selection_modal_action">
                        <button type="submit" class="btn btn-default approve">Suchparameter übernehmen</button>
                        <button type="button" class="btn btn-default deny" data-dismiss="modal">Abbrechen</button>
                    </form>
                </div> <!-- /.modal-footer -->
            </div> <!-- /.modal-content -->
        </div> <!-- /.modal-dialog -->
    </div> <!-- /.modal -->
[% END %]

[% MACRO jsinclude BLOCK %]
[% INCLUDE 'select2.inc' %]
[% INCLUDE 'calendar.inc' %]
[% INCLUDE 'datatables.inc' %]
[% INCLUDE 'format_price.inc' %]

    [% Asset.js("lib/jquery/plugins/jquery.dataTables.columnFilter.js") | $raw %]
    <script>
    
    var lateClaimConfig = {
                              library_id: '[% library_id | html %]',
                              category_id: '[% category_id | html %]',
                              level_configuration: [
                                  {
                                      level: 0,
                                      outstanding_fee_limit: 0,
                                      patron_selections: [],
                                      ban_actions: [],
                                      unban_actions: []
                                  }
                              ]
                          };
    var currency = '[% currency | html %]';
    
    var patron_attributes_lib = new Array();
    var patron_attributes_values = new Array();
    
    var values = new Array();
    var lib = new Array();
    [% FOREACH pav IN patron_attributes_values %]
        values = new Array();
        lib = new Array();
        [% FOREACH option IN pav.options %]
            values.push("[% option.lib | html %]");
            lib.push("[% option.authorised_value | html %]");
        [% END %]
        patron_attributes_lib["[% pav.attribute_code | html %]"] = values;
        patron_attributes_values["[% pav.attribute_code | html %]"] = lib;
    [% END %]
    
    function updateAttrValues (select_attr) {
        var attr_code = $(select_attr).val();
        var selected_option = $(select_attr).find("option:selected");
        
        var type = $(selected_option).attr('data-type');
        var category = $(selected_option).attr('data-category');
        
        var li_node = $(select_attr).parent();
        var span = $('span.late_payment_claim_action_attribute_value');
        var information_category_node = $(li_node).find('span.information_category');
        information_category_node.html("");

        if ( category && category.length > 0 ) {
            information_category_node.html(_("Dieses Benutzerattribut wird nur angewendet auf den Benutzertyp %s").format(category));
        }
        if ( type == 'select' ) {
            var options = '<option value = ""></option>';
            for ( var i = 0 ; i < patron_attributes_values[attr_code].length ; i++ ) {
                options += '<option value="'+patron_attributes_values[attr_code][i]+'">'+patron_attributes_lib[attr_code][i]+'</option>';
            }
            span.html('<select name="late_payment_claim_action_set_field_attribute_value" id="late_payment_claim_action_set_field_attribute_value">' + options + '</select>');
        } else if ( $(selected_option).val() != "" ) {
            span.html('<input type="text" name="late_payment_claim_action_set_field_attribute_value" id="late_payment_claim_action_set_field_attribute_value" maxlength="250"/>');
        } 
    }
    
    function updateDebitDefault(select_attr) {
        var selected_option = $(select_attr).find("option:selected");
        var defaultVal = new Number($(selected_option).attr('data-default')) || 0;
        var defaultDescription = $(selected_option).attr('data-description');
        defaultVal = defaultVal.escapeHtml().format_price().replace(",",".");
        $('#late_payment_claim_action_fee_amount').val(defaultVal);
        $('#late_payment_claim_action_fee_description').val(defaultDescription);
    }
    
    function updateLetterTransportType(select_attr) {
        var selected_option = $(select_attr).find("option:selected");
        var transports = $(selected_option).attr('data-transports');
        $("#late_payment_claim_action_letter_transport_type").empty();
        transports.split(",").forEach(function (item) {
            if ( item == "print" ) {
                $('#late_payment_claim_action_letter_transport_type').append($('<option>', { value: 'print', text: 'Brief' }));
            }
            else if ( item == "email" ) {
                $('#late_payment_claim_action_letter_transport_type').append($('<option>', { value: 'email', text: 'E-Mail' }));
            }
        });
        $("#late_payment_claim_action_letter_transport_type")[0].selectedIndex = 0;
    }

    
    $(document).ready(function(){
        [% IF action == "edit_config" %]
        $('select[name="late_payment_claim_action_set_field_attribute_code"]').change(function() {
            updateAttrValues(this);
        } );
        $('select[name="late_payment_claim_action_set_field_attribute_code"]').change();
        
        $('select[name="late_payment_claim_action_fee_debit_type"]').change(function() {
            updateDebitDefault(this);
        } );
        $('select[name="late_payment_claim_action_fee_debit_type"]').change();
        
        $('select[name="late_payment_claim_action_letter"]').change(function() {
            updateLetterTransportType(this);
        } );
        $('select[name="late_payment_claim_action_letter"]').change();
        
        $("#patron_selection_modal_action").on("submit",function(event) {
            event.preventDefault();
            var searchfields = getSearchParams();
            var level = $('#add_latepayment_patron_search_form').data("level");
            var index = $('#add_latepayment_patron_search_form').data("index");
            var config = getLateClaimConfigLevelConfiguration(level);
            if ( index == 'new' ) {
                index = config.patron_selections.length;
                config.patron_selections.push(searchfields);
                addLatePaymentClaimLevelSelection(level,searchfields,index);
            }
            else {
                config.patron_selections[index] = searchfields;
                updateLatePaymentClaimLevelSelection(level,searchfields,index);
            }
            var modal = $("#patron_selection");
            modal.modal("hide");
        });
        $("#action_selection_modal_action").on("submit",function(event) {
            event.preventDefault();
            var action = getActionParams();
            if ( action ) {
                var level = $('#add_latepayment_action_form').data("level");
                var index = $('#add_latepayment_action_form').data("index");
                var config = getLateClaimConfigLevelConfiguration(level);
                if ( index == 'new' ) {
                    index = config.ban_actions.length;
                    config.ban_actions.push(action);
                    addLatePaymentClaimLevelAction(level,action,index);
                }
                else {
                    config.ban_actions[index] = action;
                    updateLatePaymentClaimLevelAction(level,action,index);
                }
            }
            var modal = $("#action_selection");
            modal.modal("hide");
        });
        loadLatePaymentClaimLevelConfig();
        [% END %]
    });
    
    function latepayment_config_action_new() {
        var branchcode = $("#latepayment_config_branchcode").val();
        var categorycode = $("#latepayment_config_categorycode").val();

        var url = '/cgi-bin/koha/plugins/run.pl?class=[% CLASS | uri %]&method=configure&do=edit&library_id='+ encodeURI(branchcode) + '&category_id='+ encodeURI(categorycode);
        document.location = url;
    }
    
    function loadLatePaymentClaimLevelConfig() {
        let options = {
            url: '/api/v1/contrib/latepaymentclaiming/configuration/[% library_id | uri %]/[% category_id | uri %]',
            accepts: { text: "application/json" }
        };
        $.ajax(options)
        .then(function(result) {
            lateClaimConfig = result;
            if ( lateClaimConfig.level_configuration.length == 0 ) {
                lateClaimConfig.level_configuration.push({
                                      level: 0,
                                      outstanding_fee_limit: 0,
                                      patron_selections: [],
                                      ban_actions: [],
                                      unban_actions: []
                                  });
            }
            for (let i = 0; i < lateClaimConfig.level_configuration.length; i++) {
                lateClaimConfig.level_configuration[i].ban_actions = readBanActions(lateClaimConfig.level_configuration[i].ban_actions);
                if ( parseInt(lateClaimConfig.level_configuration[i].level) > 0 )
                    addLatePaymentClaimLevel(lateClaimConfig.level_configuration[i]);
            }
        });
    }
    
    function deleteLatePaymentClaimConfig(library_id,category_id) {
        if ( library_id.length == 0 ) library_id = '*';
        if ( category_id.length == 0 ) category_id = '*';
        
        let options = {
            url: '/api/v1/contrib/latepaymentclaiming/configuration/' + encodeURI(library_id) + '/' + encodeURI(category_id),
            method: 'DELETE',
            accepts: { text: "application/json" }
        };
        $.ajax(options)
        .then(function(result) {
            var url = '/cgi-bin/koha/plugins/run.pl?class=[% CLASS | uri %]&method=configure';
            document.location = url;
        });
    }
    
    function readBanActions(readBanActions) {
        var banActions = [];
        readBanActions.forEach((readAction, index) => {
            var banAction = { name: readAction.action, params: {}, description: readAction.description };
            readAction.parameter.forEach((parameter, index) => {
                banAction.params[parameter.parameter_name] = parameter.parameter_value;
            });
            banActions.push(banAction);
        });
        return banActions;
    }
    
    function writeBanActions(writeBanActions) {
        var banActions = [];
        writeBanActions.forEach((writeAction, index) => {
            var banAction = { action: writeAction.name, parameter: [], description: writeAction.description };
            Object.keys(writeAction.params).forEach(prop => {
                banAction.parameter.push({ parameter_name: prop, parameter_value: writeAction.params[prop] });
            });
            banActions.push(banAction);
        });
        return banActions;
    }
    
    function saveLatePaymentClaimLevelConfig() {
        let writeLateClaimConfig = JSON.parse(JSON.stringify(lateClaimConfig))
        for (let i = 0; i < writeLateClaimConfig.level_configuration.length; i++) {
            writeLateClaimConfig.level_configuration[i].ban_actions = writeBanActions(writeLateClaimConfig.level_configuration[i].ban_actions);
        }
        let options = {
            url: '/api/v1/contrib/latepaymentclaiming/configuration/[% library_id | uri %]/[% category_id | uri %]',
            method: 'POST',
            data: JSON.stringify(writeLateClaimConfig),
            contentType: 'application/json',
            success: function(){
                $('.show-late-payment-claim-config-save-success').css('display','block');
                setTimeout(function() {
                    $('.show-late-payment-claim-config-save-success').css('display','none');
                }, 3000);
            },
            error: function(){
                $('.show-late-payment-claim-config-save-error').css('display','block');
                setTimeout(function() {
                    $('.show-late-payment-claim-config-save-error').css('display','none');
                }, 10000);
            },
        };
        $.ajax(options);
    }
    
    function addLatePaymentClaimLevelConfig() {
        var levelConfig = {
                        level: lateClaimConfig.level_configuration.length,
                        outstanding_fee_limit: null,
                        patron_selections: [],
                        ban_actions: [],
                        unban_actions: []
                     };
        lateClaimConfig.level_configuration.push(levelConfig);
        addLatePaymentClaimLevel(levelConfig,true);
    }
    
    function addLatePaymentClaimLevel(levelConfig,doScroll) {
        var addLevelEntry = $("#latepayment_claim_config_default .latepayment_claim").clone();
        addLevelEntry.find(".latepayment_claimlevel_number").text(levelConfig.level);
        addLevelEntry.attr('id','latepayment_claim_' + levelConfig.level);
        addLevelEntry.find(".latepayment_claimlevel_delete").on( "click", function() {
            deleteLatePaymentClaimLevel(levelConfig.level);
        });
        addLevelEntry.find(".latepayment_claimlevel_add_selection").on( "click", function() {
            newLatePaymentClaimLevelSelection(levelConfig.level);
        });
        addLevelEntry.find(".latepayment_claimlevel_add_action").on( "click", function() {
            newClaimLevelAction(levelConfig.level);
        });
        
        $("#latepayment_claim_config").append(addLevelEntry);
        levelConfig.patron_selections.forEach((item, index) => {
            addLatePaymentClaimLevelSelection(levelConfig.level,item,index);
        });
        levelConfig.ban_actions.forEach((item, index) => {
            addLatePaymentClaimLevelAction(levelConfig.level,item,index);
        });
        if ( doScroll ) {
            $("#latepayment_claim_" + levelConfig.level).get(0).scrollIntoView();
        }
    }
    
    function addLatePaymentClaimLevelSelection(level,item,index) {
        var addRow = $('<tr class="latepayment_userselection_' + index + '">' + 
                                                   '<td class="latepayment_userselection_nr"></td>' + 
                                                   '<td class="latepayment_userselection_list"><ul></ul></td>' + 
                                                   '<td class="latepayment_userselection_actions">' + 
                                                   '<a class="btn btn-xs latepayment_patron_selection_do_edit"><i class="fa fa-pencil-square-o" aria-hidden="true"></i> Bearbeiten</a>' + 
                                                   '<a class="btn btn-xs latepayment_patron_selection_do_find"><i class="fa fa-list" aria-hidden="true"></i> Benutzerliste</a>' + 
                                                   '<a class="btn btn-xs latepayment_patron_selection_do_delete"><i class="fa fa-times" aria-hidden="true"></i> Löschen</a>' + 
                                                   '</td>');
        item.forEach((selection, index) => {
            addRow.find(".latepayment_userselection_list ul").append($('<li>').append(selection.description));
        });
        addRow.find(".latepayment_userselection_nr").append(index+1);
        addRow.find(".latepayment_patron_selection_do_edit").on( "click", function() {
            editLatePaymentSelectionList(level,index);
        });
        addRow.find(".latepayment_patron_selection_do_find").on( "click", function() {
            showPatronsOfLatePaymentSelectionList(level,index);
        });
        addRow.find(".latepayment_patron_selection_do_delete").on( "click", function() {
            deleteLatePaymentSelectionList(level,index);
        });
        
        $("#latepayment_claim_" + level + " .latepayment_userselections_body").append(addRow);
    }
    
    function addLatePaymentClaimLevelAction(level,action,index) {
        var addRow = $('<tr class="latepayment_action_' + index + '">' + 
                                                   '<td class="latepayment_action_nr"></td>' + 
                                                   '<td class="latepayment_action_list"><ul></ul></td>' + 
                                                   '<td class="latepayment_actio_actions">' + 
                                                   '<a class="btn btn-xs latepayment_action_do_edit"><i class="fa fa-pencil-square-o" aria-hidden="true"></i> Bearbeiten</a>' + 
                                                   '<a class="btn btn-xs latepayment_action_do_delete"><i class="fa fa-times" aria-hidden="true"></i> Löschen</a>' + 
                                                   '</td>');
        addRow.find(".latepayment_action_list ul").append($('<li>').append(action.description));

        addRow.find(".latepayment_action_nr").append(index+1);
        addRow.find(".latepayment_action_do_edit").on( "click", function() {
            editLatePaymentActionList(level,index);
        });
        addRow.find(".latepayment_action_do_delete").on( "click", function() {
            deleteLatePaymentActionList(level,index);
        });
        
        $("#latepayment_claim_" + level + " .latepayment_actions_body").append(addRow);
    }
    
    function updateLatePaymentClaimLevelSelection(level,item,index) {
        var row = $('#latepayment_claim_' + level + ' .latepayment_userselection_' + index);
        row.find(".latepayment_userselection_list ul").empty();
        item.forEach((selection, index) => {
            row.find(".latepayment_userselection_list ul").append($('<li>').append(selection.description));
        });
    }
    
    function updateLatePaymentClaimLevelAction(level,item,index) {
        var row = $('#latepayment_claim_' + level + ' .latepayment_action_' + index);
        row.find(".latepayment_action_list ul").empty();
        row.find(".latepayment_action_list ul").append($('<li>').append(item.description));
    }
    
    function editLatePaymentSelectionList(level,index) {
        var modal = $("#patron_selection");
        var config = getLateClaimConfigLevelConfiguration(level);
        var searchfields = config.patron_selections[index];
        resetSearchParams();
        setSearchParams(searchfields);
        $('#add_latepayment_patron_search_form').data("level",level);
        $('#add_latepayment_patron_search_form').data("index",index);
        modal.modal("show");
    }
    
    function editLatePaymentActionList(level,index) {
        var modal = $("#action_selection");
        var config = getLateClaimConfigLevelConfiguration(level);
        var action = config.ban_actions[index];
        resetActionParams();
        setActionParams(action);
        $('#add_latepayment_action_form').data("level",level);
        $('#add_latepayment_action_form').data("index",index);
        modal.modal("show");
    }
    
    var patronSearchResult;

    function showPatronsOfLatePaymentSelectionList(level,index) {
        var modal = $("#selection_patron_list");
        var config = getLateClaimConfigLevelConfiguration(level);
        var searchfields = config.patron_selections[index];
        modal.modal("show");
        
        if ( patronSearchResult ) {
            patronSearchResult.destroy();
        }
        
        patronSearchResult = $("#patronSearchResult").DataTable($.extend(true, {}, dataTablesDefaults, {
                "serverSide": true,
                'deferRender': true,
                'paging': true,
                'pageLength': 10,
                'lengthMenu': [[10, 20, 50, 100, -1], [10, 20, 50, 100, __('Alle')]],
                'pagingType': 'full_numbers',
                'processing': true,
                'fixedHeader': true,
                'columns': [
                    {
                         name: 'cardnumber', 
                         data: 'cardnumber',
                         sWidth: "10%",
                         render: function ( data, type, row, meta ) {
                             let patron_id = encodeURIComponent(row.patron_id);
                             return "<a href=\"/cgi-bin/koha/circ/circulation.pl?borrowernumber=" + patron_id + "\" title=\"Check out\" class=\"patron_name\" data-borrowernumber=\"" + patron_id + "\" style=\"white-space:pre-wrap;word-break:break-all;hyphens:auto;overflow-wrap:break-word;\">" + escape_str(data) + "</a>";
                         }
                    },
                    { 
                         name: 'surname',
                         data: 'me.surname:me.firstname:me.middle_name:me.othernames:me.street_number:me.address:me.address2:me.city:me.state:me.postal_code:me.country',
                         sWidth: "20%",
                         render: function ( data, type, row, meta ) {
                             let patron_id = encodeURIComponent(row.patron_id);
                             let r = '';
                            
                             r += "<a href=\"/cgi-bin/koha/members/moremember.pl?borrowernumber=" + patron_id + "\" class=\"patron_name\" data-borrowernumber=\"" + patron_id + "\" style=\"white-space:pre-wrap;word-break:break-all;hyphens:auto;overflow-wrap:break-word;\">" + $patron_to_html(row, { invert_name: 1 }) + "</a>";
                            
                             r += '<br/>';
                             r += '<div class="address"><ul>';
                             r += $format_address(row, { no_line_break: true, include_li: true });

                             if ( row.email ) {
                                 r += "<li>" + _("Email: ") + "<a href='mailto:" + encodeURIComponent(row.email) + "'>" + escape_str(row.email) + "</a></li>";
                             }
                             r += '</ul></div>'

                            return r;
                         }
                    },
                    { 
                        name: 'account_balance',
                        data: 'account_balance',
                        orderable: false,
                        sWidth: "5%",
                        "render": function( data, type, row, meta ) {
                            let r = "<span style='text-align: right; display: block;'><a href=\"/cgi-bin/koha/members/boraccount.pl?borrowernumber="+row.patron_id+"\">";
                            let balance_str = row.account_balance || 0;
                            balance_str = balance_str.escapeHtml().format_price();
                            if ( row.account_balance < 0 ) {
                                // FIXME Format price here
                                r += "<span class='credit'>" + balance_str + "</span>";
                            } else if ( row.account_balance > 0 ) {
                                r += "<span class='debit'><strong>" + balance_str  + "</strong></span>"
                            } else {
                                r += balance_str;
                            }
                            r += "</a></span>";
                            return r;
                        }
                    },
                    { 
                        name: 'date_of_birth',  
                        data: 'date_of_birth',
                        sWidth: "10%",
                        render: function( data, type, row, meta ) {
                            return data ? "<span class=\"dateofbirth\">" + escape_str($date(data)) + "<span class=\"agehint\"> (" + _("%s Jahre").format($get_age(data)) + ")</span></span>" : "";
                        }
                    },
                    { 
                        name: 'library_id',
                        data: 'library_id',
                        sWidth: "13%",
                        render: function( data, type, row, meta ) {
                            let library_name = libraries_map[data].branchname
                            if( !singleBranchMode && data == logged_in_library_id ) {
                                return "<span class=\"currentlibrary\">" + escape_str(library_name) + "</span>";
                            } else {
                                return escape_str(library_name);
                            }
                        }
                    },
                    {
                        name: 'category_id',
                        data: 'category_id',
                        sWidth: "12%",
                        render: function( data, type, row, meta ) {
                            return escape_str(categories_map[data.toLowerCase()].description);
                        }
                    },
                    { 
                        name: 'expiry_date',
                        data: 'expiry_date',
                        sWidth: "10%",
                        render: function( data, type, row, meta ) {
                            return data ? escape_str($date(data)) : "";
                        }
                    },
                    { 
                        name: 'checkouts_count:overdues_count',
                        data: 'echeckouts',
                        sWidth: "7%",
                        orderable: false,
                        "render": function( data, type, row, meta ) {
                            if ( row.overdues_count ) {
                                return "<span class='overdue'><strong>"+row.overdues_count + "</strong></span>" + " / " + row.checkouts_count;
                            } else {
                                return "0 / " + row.checkouts_count;
                            }
                        }
                    },
                    { 
                        name: 'staff_notes',
                        data: 'staff_notes',
                        sWidth: "13%",
                        render: function( data, type, row, meta ) {
                            return escape_str(row.staff_notes);
                        }
                    }
                ],
                "order": [[ 1, "asc" ]],
                "language": {
                    "paginate": {
                                "first":      "Erste",
                                "last":       "Letzte",
                                "next":       "Nächste",
                                "previous":   "Vorige"
                    },
                    "search":         "Suchen: ",
                    "emptyTable":     "Keine Daten gefunden",
                    "info":           "Zeige _START_ bis _END_ von _TOTAL_ Benutzer",
                    "infoEmpty":      "Zeige 0 bis 0 von 0 Benutzer",
                    "infoFiltered":   "(gefiltert von _MAX_ Benutzer gesamt)",
                    "lengthMenu":     "Zeige _MENU_ Benutzer",
                },
                "buttons": [{
                    fade: 100,
                    className: "dt_button_clear_filter",
                    titleAttr: __('Suche leeren'),
                    enabled: false,
                    text: '<i class="fa fa-lg fa-remove"></i> <span class="dt-button-text">' + __('Suche leeren') + '</span>',
                    action: function ( e, dt, node ) {
                        dt.search( "" ).draw("page");
                        node.addClass("disabled");
                    }
                }],
                "fnServerData": function(sSource, aoData, fnCallback) {
                    var select = { 
                                    library_id: lateClaimConfig.library_id, 
                                    category_id: lateClaimConfig.category_id, 
                                    level: config.level,
                                    patron_selection: config.patron_selections[index],
                                    search_options: aoData
                                 };
                    var page = 1;
                    var per_page = 10;
                    var order_by = '';
                    var sortcols = [];
                    var colind = 0;
                    for (var i=0; i<aoData.length;i++) {
                        if ( aoData[i].name == 'length' ) {
                            per_page = aoData[i].value;
                        }
                        if ( aoData[i].name == 'columns' ) {
                            colind = i;
                        }
                    }
                    for (var i=0; i<aoData.length;i++) {
                        if ( aoData[i].name == 'start' ) {
                            page = (aoData[i].value / per_page) + 1;
                        }
                    }
                    for (var i=0; i<aoData.length; i++) {
                        if ( aoData[i].name == 'order' ) {
                            var orderArray = new Array();
                            for (var k=0; k<aoData[i].value.length; k++) {
                                var colnum = aoData[i].value[k].column;
                                var sortcol = aoData[colind].value[colnum].data.split(':');
                                var sortdir = aoData[i].value[k].dir == 'asc' ? '+' : '-';
                                Array.prototype.push.apply(orderArray,sortcol.map(x => sortdir + (!x.includes('.')?'me.'+x:x)));
                            }
                            order_by = orderArray.filter((v, i, a) => a.indexOf(v) === i).join(',');
                        }
                    }
                    var url = '/api/v1/contrib/latepaymentclaiming/patrons/list?_page=' + encodeURIComponent(page) + '&_per_page=' + encodeURIComponent(per_page) + '&_order_by=' + encodeURIComponent(order_by);
                    $.ajax({
                        dataType: 'json',
                        contentType: 'application/json',
                        type: 'POST',
                        url: url,
                        data: JSON.stringify(select),
                        beforeSend: function(request) {
                            request.setRequestHeader("x-koha-embed","extended_attributes,checkouts+count,overdues+count,account_balance");
                        },
                        success: function(json){
                            fnCallback(json);
                        }
                    })
                },
            }));
    }
    
    function getLateClaimConfigLevelConfiguration(level) {
        var claimLevelConfig;
        lateClaimConfig.level_configuration.forEach((config, index) => {
            if ( parseInt(config.level) === parseInt(level) )
                claimLevelConfig = config;
        });
        return claimLevelConfig;
    }
    
    
    function deleteLatePaymentClaimLevel(level) {
        var index = 0;
        for (let i = 1; i < lateClaimConfig.level_configuration.length; i++) {
            if ( parseInt(lateClaimConfig.level_configuration[i].level) === parseInt(level) )
                index = i;
        }
        lateClaimConfig.level_configuration.splice(index, 1);
        for (let i = 1; i < lateClaimConfig.level_configuration.length; i++) {
            if ( parseInt(lateClaimConfig.level_configuration[i].level) >= parseInt(level) )
                lateClaimConfig.level_configuration[i].level = parseInt(lateClaimConfig.level_configuration[i].level) - 1;
        }
        $('#latepayment_claim_config').empty();

        for (let i = 1; i < lateClaimConfig.level_configuration.length; i++) {
            if ( parseInt(lateClaimConfig.level_configuration[i].level) > 0 )
                addLatePaymentClaimLevel(lateClaimConfig.level_configuration[i]);
        }
    }
    
    function deleteLatePaymentSelectionList(level,index) {
        var config = getLateClaimConfigLevelConfiguration(level);
        $('#latepayment_claim_' + level + ' .latepayment_userselections_body').empty();
        config.patron_selections.splice(index, 1);
        config.patron_selections.forEach((item, index) => {
            addLatePaymentClaimLevelSelection(config.level,item,index);
        });
    }
    
    function deleteLatePaymentActionList(level,index) {
        var config = getLateClaimConfigLevelConfiguration(level);
        $('#latepayment_claim_' + level + ' .latepayment_actions_body').empty();
        config.ban_actions.splice(index, 1);
        config.ban_actions.forEach((item, index) => {
            addLatePaymentClaimLevelAction(config.level,item,index);
        });
    }
    
    function newLatePaymentClaimLevelSelection(level) {
        var modal = $("#patron_selection");
        resetSearchParams();
        $('#add_latepayment_patron_search_form').data("level",level);
        $('#add_latepayment_patron_search_form').data("index","new");
        modal.modal("show");
    }
    
    function newClaimLevelAction(level) {
        var modal = $("#action_selection");
        resetActionParams();
        $('#add_latepayment_action_form').data("level",level);
        $('#add_latepayment_action_form').data("index","new");
        modal.modal("show");
    }
    
    function getSearchParams(searchfields) {
        var searchfields = [];
        var description;
        if ( $("#latepayment_search_claim_filter").val().length > 0 )
        {
            var description = 'Gebührenmahnstufe (' + 
                                $("#latepayment_search_claim_filter option:selected").text() +
                                ') erreicht' ;
            if ( $("#latepayment_search_claimdays_filter").val().length )
                description += ' vor '  +
                                $("#latepayment_search_claimdays_filter").val() +
                                ' Tagen';
            if ( $("#latepayment_search_claim_filter_negate").prop('checked') == true )
                description = 'Nicht: ' + description;
            
            searchfields.push({ search_field: "late_payment_claim", 
                                search_type: $("#latepayment_search_claim_filter").val(), 
                                search_value: $("#latepayment_search_claimdays_filter").val(), 
                                negate: $("#latepayment_search_claim_filter_negate").prop('checked'),
                                description: description });
        }
        if ( $("#latepayment_search_patron_filter").val().trim().length > 0 )
        {
            var description = 'Benutzerdatenfeld (' + 
                                $("#latepayment_search_patron_field_filter option:selected").text()  + ') ' + 
                                $("#latepayment_search_patron_searchtype_filter option:selected").text()  + ' ' + 
                                $("#latepayment_search_patron_filter").val().trim();
            if ( $("#latepayment_search_patron_filter_negate").prop('checked') == true )
                description = 'Nicht: ' + description;

            searchfields.push({ search_field: "patron_field", 
                                search_value: $("#latepayment_search_patron_filter").val().trim(), 
                                search_fieldset: $("#latepayment_search_patron_field_filter").val(), 
                                search_type: $("#latepayment_search_patron_searchtype_filter").val(),
                                negate: $("#latepayment_search_patron_filter_negate").prop('checked'),
                                description: description });
        }
        if ( $("#latepayment_search_agerangestart_filter").val().trim().length > 0 ||
             $("#latepayment_search_agerangeend_filter").val().trim().length > 0 )
        {
            var description = 'Alter des Benutzers ist mindestens ';
            if ( $("#latepayment_search_agerangestart_filter").val().trim().length > 0 )
                description += $("#latepayment_search_agerangestart_filter").val().trim();
            if ( $("#latepayment_search_agerangeend_filter").val().trim().length > 0 )
                description += " bis " + $("#latepayment_search_agerangeend_filter").val().trim();
            description += " Jahre";
            if ( $("#latepayment_search_agerange_filter_negate").prop('checked') == true )
                description = 'Nicht: ' + description;

            searchfields.push({ search_field: "age_range", 
                                search_from: $("#latepayment_search_agerangestart_filter").val().trim(), 
                                search_to: $("#latepayment_search_agerangeend_filter").val(),
                                negate: $("#latepayment_search_agerange_filter_negate").prop('checked'),
                                description: description });
        }
        if ( $("#latepayment_search_issuecountstart_filter").val().trim().length > 0 ||
             $("#latepayment_search_issuecountend_filter").val().trim().length > 0 )
        {
            var description = 'Benutzer hat mindestens ';
            if ( $("#latepayment_search_issuecountstart_filter").val().trim().length > 0 )
                description += $("#latepayment_search_issuecountstart_filter").val().trim();
            if ( $("#latepayment_search_issuecountend_filter").val().trim().length > 0 )
                description += " bis " + $("#latepayment_search_issuecountend_filter").val().trim();
            description += " Medien ausgeliehen";
            if ( $("#latepayment_search_issuecount_filter_negate").prop('checked') == true )
                description = 'Nicht: ' + description;
            
            searchfields.push({ search_field: "issue_count", 
                                search_from: $("#latepayment_search_issuecountstart_filter").val().trim(), 
                                search_to: $("#latepayment_search_issuecountend_filter").val(),
                                negate: $("#latepayment_search_issuecount_filter_negate").prop('checked'),
                                description: description });
        }
        if ( $("#latepayment_search_chargesfrom_filter").val().trim().length > 0 ||
             $("#latepayment_search_chargesto_filter").val().trim().length > 0 )
        {
            var description = 'Benutzer hat ausstehende Gebühren in Höhe';
            if ( $("#latepayment_search_chargesfrom_filter").val().trim().length > 0 )
                description += " von " + $("#latepayment_search_chargesfrom_filter").val().trim() + " " + currency;
            if ( $("#latepayment_search_chargesto_filter").val().trim().length > 0 )
                description += " bis " + $("#latepayment_search_chargesto_filter").val().trim() + " " + currency;
            if ( $("#latepayment_search_charges_filter_negate").prop('checked') == true )
                description = 'Nicht: ' + description;

            searchfields.push({ search_field: "charges_amount", 
                                search_from: $("#latepayment_search_chargesfrom_filter").val().trim(), 
                                search_to: $("#latepayment_search_chargesto_filter").val(),
                                negate: $("#latepayment_search_charges_filter_negate").prop('checked'),
                                description: description });
        }
        if ( $("#latepayment_search_chargessince_filter").val().trim().length > 0 )
        {
            var description = 'Benutzer hat ausstehende Gebühren seit ' + $("#latepayment_search_chargessince_filter").val().trim() + ' Tagen';
            if ( $("#latepayment_search_charges_filter_negate").prop('checked') == true )
                description = 'Nicht: ' + description;

            searchfields.push({ search_field: "charges_since", 
                                search_value: $("#latepayment_search_chargessince_filter").val().trim(), 
                                negate: $("#latepayment_search_charges_filter_negate").prop('checked'),
                                description: description });
        }
        if ( $("#latepayment_search_accountexpiresfrom_filter").val().trim().length > 0 )
        {
            var description = 'Benutzerkonto lief ab ';
            if ( $("#latepayment_search_accountexpiresfrom_filter").val().trim().length > 0 )
                description += " vor " + $("#latepayment_search_accountexpiresfrom_filter").val().trim();
            if ( $("#latepayment_search_accountexpiresto_filter").val().trim().length > 0 )
                description += " bis " + $("#latepayment_search_accountexpiresto_filter").val().trim();
            description += " Tagen";
            if ( $("#latepayment_search_accountexpires_filter_negate").prop('checked') == true )
                description = 'Nicht: ' + description;
    
            searchfields.push({ search_field: "account_expired", 
                                search_from: $("#latepayment_search_accountexpiresfrom_filter").val().trim(), 
                                search_to: $("#latepayment_search_accountexpiresto_filter").val(),
                                negate: $("#latepayment_search_accountexpires_filter_negate").prop('checked'),
                                description: description });
        }
        if ( $("#latepayment_search_debarreduntilfrom_filter").val().trim().length > 0 )
        {
            var description = 'Benutzer gesperrt ';
            if ( $("#latepayment_search_debarreduntilfrom_filter").val().trim().length > 0 )
                description += " vor " + $("#latepayment_search_debarreduntilfrom_filter").val().trim();
            if ( $("#latepayment_search_debarreduntilto_filter").val().trim().length > 0 )
                description += " bis " + $("#latepayment_search_debarreduntilto_filter").val().trim();
            description += " Tagen";
            if ( $("#latepayment_search_debarreduntil_filter_negate").prop('checked') == true )
                description = 'Nicht: ' + description;

            searchfields.push({ search_field: "debarred_until", 
                                search_from: $("#latepayment_search_debarreduntilfrom_filter").val().trim(), 
                                search_to: $("#latepayment_search_debarreduntilto_filter").val(),
                                negate: $("#latepayment_search_debarreduntil_filter_negate").prop('checked'),
                                description: description });
        }
        if ( $("#latepayment_search_inactivesince_filter").val().trim().length > 0 )
        {
            var description = 'Benutzer war inaktiv seit ' + $("#latepayment_search_inactivesince_filter").val().trim() + ' Tagen';
            if ( $("#latepayment_search_inactivesince_filter_negate").prop('checked') == true )
                description = 'Nicht: ' + description;

            searchfields.push({ search_field: "inactive_since", 
                                search_value: $("#latepayment_search_inactivesince_filter").val().trim(), 
                                negate: $("#latepayment_search_inactivesince_filter_negate").prop('checked'),
                                description: description });
        }
        if ( $("#latepayment_search_lastlettercode_filter").val().trim().length > 0 )
        {
            var description = 'Letzte Benachrichtigung war ' + $("#latepayment_search_lastlettercode_filter option:selected").text() + '';
            if ( $("#latepayment_search_lastlettercode_filter_negate").prop('checked') == true )
                description = 'Nicht: ' + description;

            searchfields.push({ search_field: "last_letter_code", 
                                search_value: $("#latepayment_search_lastlettercode_filter").val().trim(), 
                                negate: $("#latepayment_search_lastlettercode_filter_negate").prop('checked'),
                                description: description });
        }
        if ( $("#latepayment_search_overduelevel_filter").val().trim().length > 0 )
        {
            var description = 'Benutzer hat Ausleihe mit Mahnstufe (' + $("#latepayment_search_overduelevel_filter option:selected").text() + ')';
            if ( $("#latepayment_search_overduelevel_filter_negate").prop('checked') == true )
                description = 'Nicht: ' + description;
                
            searchfields.push({ search_field: "overdue_level", 
                                search_value: $("#latepayment_search_overduelevel_filter").val().trim(), 
                                negate: $("#latepayment_search_overduelevel_filter_negate").prop('checked'),
                                description: description });
        }
        if ( $("#latepayment_search_validemailavailable_filter").val().trim().length > 0 )
        {
            var description = 'E-Mail-Adresse ' + $("#latepayment_search_validemailavailable_filter option:selected").text() + '';
            if ( $("#latepayment_search_validemailavailable_filter_negate").prop('checked') == true )
                description = 'Nicht: ' + description;

            searchfields.push({ search_field: "valid_email", 
                                search_value: $("#latepayment_search_validemailavailable_filter").val().trim(), 
                                negate: $("#latepayment_search_validemailavailable_filter_negate").prop('checked'),
                                description: description });
        }
        if ( $("#latepayment_search_patronlistid_filter").val().trim().length > 0 )
        {
            var description = 'In Benutzerliste "' + $("#latepayment_search_patronlistid_filter option:selected").text() + '" enthalten';
            if ( $("#latepayment_search_patronlistid_filter_negate").prop('checked') == true )
                description = 'Nicht: ' + description;

            searchfields.push({ search_field: "patron_list", 
                                search_value: $("#latepayment_search_patronlistid_filter").val().trim(), 
                                negate: $("#latepayment_search_patronlistid_filter_negate").prop('checked'),
                                description: description });
        }
        return searchfields;
    }
    
    function getActionParams() {
        var action = {};
        var description ='';
        if ( $("a[data-tabname='action_claim_tab'").parent().hasClass("active") ) {
            description = 'Sende Benachrichtigung "' + 
                          $("#late_payment_claim_action_letter option:selected").text() + 
                          '" mit bevorzugter Versandart "' + 
                          $("#late_payment_claim_action_letter_transport_type option:selected").text() + '"';
            if ( $("#late_payment_claim_action_letter_charge").val().trim().length > 0 ) {
                description += " mit Benachrichtigungsgebühr in Höhe von " + $("#late_payment_claim_action_letter_charge").val() + " " + currency;
                if ( $("#late_payment_claim_action_letter_charge_description").val().trim().length > 0 )
                     description += " mit Beschreibung \"" + $("#late_payment_claim_action_letter_charge_description").val().trim() + "\"";
                if ( $("#late_payment_claim_action_letter_charge_note").val().trim().length > 0 )
                     description += " und Hinweis \"" + $("#late_payment_claim_action_letter_charge_note").val().trim() + "\"";
            }
            action = {
                         name: "letter",
                         params: {
                             letter: $("#late_payment_claim_action_letter").val(),
                             letter_transport_type: $("#late_payment_claim_action_letter_transport_type").val(),
                             letter_charge: $("#late_payment_claim_action_letter_charge").val(),
                             letter_charge_description: $("#late_payment_claim_action_letter_charge_description").val(),
                             letter_charge_note: $("#late_payment_claim_action_letter_charge_note").val()
                         },
                         description: description
                     };
        }
        else if ( $("a[data-tabname='action_fee_tab'").parent().hasClass("active") ) {
            description = 'Erhebe eine Gebühr "' + 
                          $("#late_payment_claim_action_fee_debit_type option:selected").text() + 
                          '" in Höhe von ' + $("#late_payment_claim_action_fee_amount").val() + " " + currency + " ";
            if ( $("#late_payment_claim_action_fee_description").val().length > 0 )
                description += ' mit der Beschreibung: "' + $("#late_payment_claim_action_fee_description").val() + '"';
            if ( $("#late_payment_claim_action_fee_note").val().length > 0 )
                description += ', Hinweis: "' + $("#late_payment_claim_action_fee_note").val() + '"';
            action = {
                         name: "fee",
                         params: {
                             fee_debit_type: $("#late_payment_claim_action_fee_debit_type").val(),
                             fee_amount: $("#late_payment_claim_action_fee_amount").val(),
                             fee_description: $("#late_payment_claim_action_fee_description").val(),
                             fee_note: $("#late_payment_claim_action_fee_note").val()
                         },
                         description: description
                     };
        }
        else if ( $("a[data-tabname='action_debarement_tab'").parent().hasClass("active") ) {
            if ( $("#late_payment_claim_action_debarement_type").length > 0 ) {
                description = 'Füge eine neue Sperre des Typs "' + 
                              $("#late_payment_claim_action_debarement_type option:selected").text() + 
                              '" mit dem Kommentar "' + $("#late_payment_claim_action_debarement_comment").val() + '" zu"';
                if ( $("#late_payment_claim_action_debarement_expiration").val().trim().length > 0 )
                    description += ', die innerhalb von ' + $("#late_payment_claim_action_debarement_expiration").val() + ' Tagen abläuft';
            } else {
                description = 'Füge eine neue Sperre mit dem Kommentar "' + $("#late_payment_claim_action_debarement_comment").val() + '" zu"';
                if ( $("#late_payment_claim_action_debarement_expiration").val().trim().length > 0 )
                    description += ', die innerhalb von ' + $("#late_payment_claim_action_debarement_expiration").val() + ' Tagen abläuft';
            }
            action = {
                         name: "debarement",
                         params: {
                             debarement_type: $("#late_payment_claim_action_debarement_type").val(),
                             debarement_comment: $("#late_payment_claim_action_debarement_comment").val(),
                             debarement_expiration: $("#late_payment_claim_action_debarement_expiration").val()
                         },
                         description: description
                     };
        }
        else if ( $("a[data-tabname='action_debarement_delete_tab'").parent().hasClass("active") ) {
            if ( $("#late_payment_claim_action_delete_debarement_all").prop('checked') ) {
                description = 'Lösche alle Sperren';
            }
            else if ( $("#late_payment_claim_action_delete_debarement_type").prop('checked') ) {
                description = 'Lösche Sperren des Typs "' +
                          $("#late_payment_claim_action_delete_debarement_types option:selected").text() + '"';
            }
            action = {
                         name: "delete_debarement",
                         params: {
                             delete_debarement_type: $("#late_payment_claim_action_delete_debarement_type").prop('checked'),
                             delete_debarement_types: $("#late_payment_claim_action_delete_debarement_types").val(),
                             delete_debarement_all: $("#late_payment_claim_action_delete_debarement_all").prop('checked')
                         },
                         description: description
                     };
        }
        else if ( $("a[data-tabname='action_user_value_tab'").parent().hasClass("active") ) {
            if ( $("#late_payment_claim_action_set_field_categorycode").val().length > 0 ) {
                if ( description.length > 0 ) description += ", ";
                description += 'den Benutzertyp auf "' + $("#late_payment_claim_action_set_field_categorycode option:selected").text() + '"';
            }
            if ( $("#late_payment_claim_action_set_field_borrowernotes").val().length > 0 ) {
                if ( description.length > 0 ) description += ", ";
                if ( $("#late_payment_claim_action_set_field_borrowernotes_append").prop('checked') == true ) {
                    description += 'die angehängte Ausleihnotiz auf "' + $("#late_payment_claim_action_set_field_borrowernotes").val() + '"';
                } else {
                    description += 'die Ausleihnotiz auf "' + $("#late_payment_claim_action_set_field_borrowernotes").val() + '"';
                }
            }
            if ( $("#late_payment_claim_action_set_field_opacnote").val().length > 0 ) {
                if ( description.length > 0 ) description += ", ";
                if ( $("#late_payment_claim_action_set_field_opacnote_append").prop('checked') == true ) {
                    description += 'die angehängte OPAC-Notiz auf "' + $("#late_payment_claim_action_set_field_opacnote").val() + '"';
                } else {
                    description += 'die OPAC-Notiz auf "' + $("#late_payment_claim_action_set_field_opacnote").val() + '"';
                }
            }
            if ( $("#late_payment_claim_action_set_field_dateexpiry_action").val().length > 0 ) {
                if ( description.length > 0 ) description += ", ";
                description += ' das Ablaufdatum "' + $("#late_payment_claim_action_set_field_dateexpiry_action option:selected").text() + '"';
            }
            if ( $("#late_payment_claim_action_set_field_attribute_value").val().length > 0 ) {
                if ( description.length > 0 ) description += ", ";
                if ( $('#late_payment_claim_action_set_field_attribute_value').get(0).tagName == "INPUT" ) {
                    description += ' das Benutzerattribut "' + $("#late_payment_claim_action_set_field_attribute_code option:selected").text() + '" auf den Wert "' +
                                   $("#late_payment_claim_action_set_field_attribute_value").val() + '"';
                } 
                else if ( $('#late_payment_claim_action_set_field_attribute_value').get(0).tagName == "SELECT" ) {
                    description += ' das Benutzerattribut "' + $("#late_payment_claim_action_set_field_attribute_code option:selected").text() + '" auf den Wert "' +
                                   $("#late_payment_claim_action_set_field_attribute_value option:selected").text() + '"';
                }
            }
            if ( description.length > 0 ) description = "Setze " + description;
            else return null;
            action = {
                         name: "set_field",
                         params: {
                             set_field_categorycode: $("#late_payment_claim_action_set_field_categorycode").val(),
                             set_field_borrowernotes: $("#late_payment_claim_action_set_field_borrowernotes").val(),
                             set_field_borrowernotes_append: $("#late_payment_claim_action_set_field_borrowernotes_append").prop('checked'),
                             set_field_opacnote: $("#late_payment_claim_action_set_field_opacnote").val(),
                             set_field_opacnote_append: $("#late_payment_claim_action_set_field_opacnote_append").prop('checked'),
                             set_field_dateexpiry_action: $("#late_payment_claim_action_set_field_dateexpiry_action").val(),
                             set_field_attribute_code: $("#late_payment_claim_action_set_field_attribute_code").val(),
                             set_field_attribute_value: $("#late_payment_claim_action_set_field_attribute_value").val()
                         },
                         description: description
                     };
        }
        else if ( $("a[data-tabname='action_add_list_tab'").parent().hasClass("active") ) {
            if ( $("#late_payment_claim_action_patron_list_add").prop('checked') ) {
                description = 'Hinzufügen zur Benutzerliste "' + $("#late_payment_claim_action_patron_list option:selected").text() + '"';
            }
            else if ( $("#late_payment_claim_action_patron_list_delete").prop('checked') ) {
                description = 'Löschen von der Benutzerliste "' + $("#late_payment_claim_action_patron_list option:selected").text() + '"';
            }
            action = {
                         name: "patron_list",
                         params: {
                             patron_list: $("#late_payment_claim_action_patron_list").val(),
                             patron_list_add: $("#late_payment_claim_action_patron_list_add").prop('checked'),
                             patron_list_delete: $("#late_payment_claim_action_patron_list_delete").prop('checked')
                         },
                         description: description
                     };
        }
        return action;
    }
    
    function setSearchParams(searchfields) {
        searchfields.forEach((item, index) => {
            switch (item.search_field) {
                case "late_payment_claim":
                    $("#latepayment_search_claim_filter").val(item.search_type);
                    $("#latepayment_search_claimdays_filter").val(item.search_value);
                    $("#latepayment_search_claim_filter_negate").prop('checked',item.negate);
                    break;
                case "patron_field":
                    $("#latepayment_search_patron_filter").val(item.search_value);
                    $("#latepayment_search_patron_field_filter").val(item.search_fieldset);
                    $("#latepayment_search_patron_searchtype_filter").val(item.search_type);
                    $("#latepayment_search_patron_filter_negate").prop('checked',item.negate);
                    break;
                case "age_range":
                    $("#latepayment_search_agerangestart_filter").val(item.search_from);
                    $("#latepayment_search_agerangeend_filter").val(item.search_to);
                    $("#latepayment_search_agerange_filter_negate").prop('checked',item.negate);
                    break;
                case "issue_count":
                    $("#latepayment_search_issuecountstart_filter").val(item.search_from);
                    $("#latepayment_search_issuecountend_filter").val(item.search_to);
                    $("#latepayment_search_issuecount_filter_negate").prop('checked',item.negate);
                    break;
                case "charges_amount":
                    $("#latepayment_search_chargesfrom_filter").val(item.search_from);
                    $("#latepayment_search_chargesto_filter").val(item.search_to);
                    $("#latepayment_search_charges_filter_negate").prop('checked',item.negate);
                    break;
                case "charges_since":
                    $("#latepayment_search_chargessince_filter").val(item.search_value);
                    $("#latepayment_search_chargessince_filter_negate").prop('checked',item.negate);
                    break;
                case "account_expired":
                    $("#latepayment_search_accountexpiresfrom_filter").val(item.search_from);
                    $("#latepayment_search_accountexpiresto_filter").val(item.search_to);
                    $("#latepayment_search_accountexpires_filter_negate").prop('checked',item.negate);
                    break;
                case "debarred_until":
                    $("#latepayment_search_debarreduntilfrom_filter").val(item.search_from);
                    $("#latepayment_search_debarreduntilto_filter").val(item.search_to);
                    $("#latepayment_search_debarreduntil_filter_negate").prop('checked',item.negate);
                    break;
                case "inactive_since":
                    $("#latepayment_search_inactivesince_filter").val(item.search_value);
                    $("#latepayment_search_inactivesince_filter_negate").prop('checked',item.negate);
                    break;
                case "last_letter_code":
                    $("#latepayment_search_lastlettercode_filter").val(item.search_value);
                    $("#latepayment_search_lastlettercode_filter_negate").prop('checked',item.negate);
                    break;
                case "overdue_level":
                    $("#latepayment_search_overduelevel_filter").val(item.search_value);
                    $("#latepayment_search_overduelevel_filter_negate").prop('checked',item.negate);
                    break;
                case "valid_email":
                    $("#latepayment_search_validemailavailable_filter").val(item.search_value);
                    $("#latepayment_search_validemailavailable_filter_negate").prop('checked',item.negate);
                    break;
                case "patron_list":
                    $("#latepayment_search_patronlistid_filter").val(item.search_value);
                    $("#latepayment_search_patronlistid_filter_negate").prop('checked',item.negate);
                    break;
            }
        });
    }
    
    function setActionParams(item) {
        switch (item.name) {
            case "letter":
                $("#late_payment_claim_action_letter").val(item.params.letter);
                $("#late_payment_claim_action_letter_transport_type").val(item.params.letter_transport_type);
                $("#late_payment_claim_action_letter_charge").val(item.params.letter_charge);
                $("#late_payment_claim_action_letter_charge_description").val(item.params.letter_charge_description);
                $("#late_payment_claim_action_letter_charge_note").val(item.params.letter_charge_note);
                $("a[data-tabname='action_claim_tab'").click();
                break;
            case "fee":
                $("#late_payment_claim_action_fee_debit_type").val(item.params.fee_debit_type);
                $("#late_payment_claim_action_fee_amount").val(item.params.fee_amount);
                $("#late_payment_claim_action_fee_description").val(item.params.fee_description);
                $("#late_payment_claim_action_fee_note").val(item.params.fee_note);
                $("a[data-tabname='action_fee_tab'").click();
                break;
            case "debarement":
                $("#late_payment_claim_action_debarement_type").val(item.params.debarement_type);
                $("#late_payment_claim_action_debarement_comment").val(item.params.debarement_comment);
                $("#late_payment_claim_action_debarement_expiration").val(item.params.debarement_expiration);
                $("a[data-tabname='action_debarement_tab'").click();
                break;
            case "delete_debarement":
                $("#late_payment_claim_action_delete_debarement_type").prop('checked',item.params.delete_debarement_type);
                $("#late_payment_claim_action_delete_debarement_types").val(item.params.delete_debarement_types);
                $("#late_payment_claim_action_delete_debarement_all").prop('checked',item.params.delete_debarement_all);
                $("a[data-tabname='action_debarement_delete_tab'").click();
                break;
            case "set_field":
                $("#late_payment_claim_action_set_field_categorycode").val(item.params.set_field_categorycode);
                $("#late_payment_claim_action_set_field_borrowernotes").val(item.params.set_field_borrowernotes);
                $("#late_payment_claim_action_set_field_borrowernotes_append").prop('checked',item.params.set_field_borrowernotes_append);
                $("#late_payment_claim_action_set_field_opacnote").val(item.params.set_field_opacnote);
                $("#late_payment_claim_action_set_field_opacnote_append").prop('checked',item.params.set_field_opacnote_append);
                $("#late_payment_claim_action_set_field_dateexpiry_action").val(item.params.set_field_dateexpiry_action);
                $("#late_payment_claim_action_set_field_attribute_code").val(item.params.set_field_attribute_code);
                $("#late_payment_claim_action_set_field_attribute_value").val(item.params.set_field_attribute_value);
                $("a[data-tabname='action_user_value_tab'").click();
                break;
            case "patron_list":
                $("#late_payment_claim_action_patron_list").val(item.params.patron_list);
                $("#late_payment_claim_action_patron_list_add").prop('checked',item.params.patron_list_add);
                $("#late_payment_claim_action_patron_list_delete").prop('checked',item.params.patron_list_delete);
                $("a[data-tabname='action_add_list_tab'").click();
                break;
        }
    }
     
    function resetSearchParams() {
        $("#latepayment_search_claim_filter")[0].selectedIndex = 0;
        $("#latepayment_search_claimdays_filter").val('');
        $("#latepayment_search_claim_filter_negate").prop('checked', false);
        
        $("#latepayment_search_patron_filter").val('');
        $("#latepayment_search_patron_field_filter")[0].selectedIndex = 0;
        $("#latepayment_search_patron_searchtype_filter")[0].selectedIndex = 0;
        $("#latepayment_search_patron_filter_negate").prop('checked', false);
        
        $("#latepayment_search_agerangestart_filter").val('');
        $("#latepayment_search_agerangeend_filter").val('');
        $("#latepayment_search_agerange_filter_negate").prop('checked', false);
        
        $("#latepayment_search_issuecountstart_filter").val('');
        $("#latepayment_search_issuecountend_filter").val('');
        $("#latepayment_search_issuecount_filter_negate").prop('checked', false);
        
        $("#latepayment_search_chargesfrom_filter").val('');
        $("#latepayment_search_chargesto_filter").val('');
        $("#latepayment_search_charges_filter_negate").prop('checked', false);
        
        $("#latepayment_search_chargessince_filter").val('');
        $("#latepayment_search_chargessince_filter_negate").prop('checked', false);
        
        $("#latepayment_search_accountexpiresfrom_filter").val('');
        $("#latepayment_search_accountexpiresto_filter").val('');
        $("#latepayment_search_accountexpires_filter_negate").prop('checked', false);
        
        $("#latepayment_search_debarreduntilfrom_filter").val('');
        $("#latepayment_search_debarreduntilto_filter").val('');
        $("#latepayment_search_debarreduntil_filter_negate").prop('checked', false);
        
        $("#latepayment_search_inactivesince_filter").val('');
        $("#latepayment_search_inactivesince_filter_negate").prop('checked', false);
        
        $("#latepayment_search_lastlettercode_filter")[0].selectedIndex = 0;
        $("#latepayment_search_lastlettercode_filter_negate").prop('checked', false);
        
        $("#latepayment_search_overduelevel_filter")[0].selectedIndex = 0;
        $("#latepayment_search_overduelevel_filter_negate").prop('checked', false);
        
