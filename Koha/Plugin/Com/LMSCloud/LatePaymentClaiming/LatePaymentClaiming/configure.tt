        $("#latepayment_search_patronlistid_filter")[0].selectedIndex = 0;
        $("#latepayment_search_patronlistid_filter_negate").prop('checked', false);
    }
    
    function resetActionParams() {
        $("#late_payment_claim_action_letter")[0].selectedIndex = 0;
        // $("#late_payment_claim_action_letter_transport_type")[0].selectedIndex = 0;
        $("#late_payment_claim_action_letter_charge").val('Benachrichtigungsgebühr für [%claim.level %]. Gebührenmahnung');
        $("#late_payment_claim_action_letter_charge").val('[%claim.level %]. Gebührenmahnung vom [% today %]');

        $("#late_payment_claim_action_fee_debit_type")[0].selectedIndex = 0;
        /*
           The next two fields will be set implicitly by a data change trigger
           of the late_payment_claim_action_fee_debit_type select box
        */
        // $("#late_payment_claim_action_fee_amount").val('0.01');
        // $("#late_payment_claim_action_fee_description").val('');
        $("#late_payment_claim_action_fee_note").val('[%claim.level %]. Gebührenmahnung vom [% today %]');
        
        $("#late_payment_claim_action_debarement_type")[0].selectedIndex = 0;
        $("#late_payment_claim_action_debarement_comment").val('');
        $("#late_payment_claim_action_debarement_expiration").val('');
        
        $('#late_payment_claim_action_delete_debarement_type').prop('checked',false);
        $('#late_payment_claim_action_delete_debarement_types')[0].selectedIndex = 0;
        $('#late_payment_claim_action_delete_debarement_all').prop('checked',true);
        
        $('#late_payment_claim_action_set_field_categorycode')[0].selectedIndex = 0;
        $("#late_payment_claim_action_set_field_borrowernotes").val('');
        $("#late_payment_claim_action_set_field_borrowernotes_append").prop('checked',true);
        $("#late_payment_claim_action_set_field_opacnote").val('');
        $("#late_payment_claim_action_set_field_opacnote_append").prop('checked',true);
        $('#late_payment_claim_action_set_field_dateexpiry_action')[0].selectedIndex = 0;
        $('#late_payment_claim_action_set_field_attribute_code')[0].selectedIndex = 0;
        if ( $('#late_payment_claim_action_set_field_attribute_value').get(0).tagName == "INPUT" ) {
            $("#late_payment_claim_action_set_field_attribute_value").val('');
        }
        else if ( $('#late_payment_claim_action_set_field_attribute_value').get(0).tagName == "SELECT" ) {
            $('#late_payment_claim_action_set_field_attribute_value')[0].selectedIndex = 0;
        }
        
        $('#late_payment_claim_action_patron_list')[0].selectedIndex = 0;
        $('#late_payment_claim_action_patron_list_add').prop('checked',true);
        $('#late_payment_claim_action_patron_list_delete').prop('checked',false);
    }
     
    </script>
    
